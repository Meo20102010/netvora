{
  "name": "netvora-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate --schema=server/prisma/schema.prisma",
    "prebuild": "prisma db push --schema=server/prisma/schema.prisma --accept-data-loss",
    "db:push": "prisma db push --schema=server/prisma/schema.prisma",
    "db:seed": "npx ts-node --project server/tsconfig.json server/src/seed.ts",
    "db:studio": "prisma studio --schema=server/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "framer-motion": "^12.42.2",
    "google-auth-library": "^10.9.0",
    "helmet": "^7.1.0",
    "hls.js": "^1.6.16",
    "js-cookie": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "next": "^14.1.0",
    "nodemailer": "^6.9.8",
    "plyr": "^3.7.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.0.1",
