    "scrape:movies": "node scraper/_scrape_movies.cjs"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@types/multer": "^2.2.0",
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "nodemailer": "^6.9.8",
    "playwright": "^1.61.1",
    "redis": "^4.6.12",
    "sql.js": "^1.14.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
